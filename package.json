{
  "name": "ironbridge-soldier-template",
  "version": "1.0.0",
  "description": "IronBridge hardened soldier runtime template — zero-trust, encrypted, self-healing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --noEmit && tsc",
    "lint": "eslint src/ --ext .ts",
    "test": "jest --coverage",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "verify-lockfile": "node -e \"const h=require('crypto').createHash('sha256').update(require('fs').readFileSync('package-lock.json')).digest('hex');console.log('lockfile-hash:'+h)\""
  },
  "dependencies": {
    "@upstash/redis": "^1.28.0",
    "@upstash/qstash": "^2.5.0",
    "better-sqlite3": "^9.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
